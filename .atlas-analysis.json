  "keyFeatures": [
    "Real-time multiplayer chess with WebSocket communication",
    "Chess puzzles with tactics training and performance tracking",
    "Tournament system with Arena, Swiss, and team battles",
    "Study and broadcast tools for chess analysis and live events",
    "Computer analysis powered by Stockfish via Fishnet cluster",
    "Comprehensive HTTP API for games, users, and tournaments",
    "Multi-language support with 140+ translations",
    "Bot API for chess engines and automated play"
  ],
  "publicApiSurface": [
    "GET /api/account - Get current user account information",
    "GET /api/user/{username} - Get user profile",
    "GET /api/games/user/{username} - Export user games",
    "GET /api/tournament - List current tournaments",
    "POST /api/tournament - Create a tournament",
    "GET /api/puzzle/daily - Get daily puzzle",
    "GET /api/study/{studyId}.pgn - Export study in PGN format",
    "GET /api/broadcast - List live broadcasts",
    "GET /api/tv/channels - Get current TV channels",
    "GET /api/stream/event - Stream incoming events (bot API)",
    "POST /api/challenge/{username} - Challenge a user",
    "POST /api/bot/game/{gameId}/move/{move} - Make a bot move",
    "GET /api/games/export/{gameId} - Export single game",
    "GET /api/user/{username}/rating-history - Get rating history",
    "POST /api/team/{teamId}/join - Join a team"
  ]
